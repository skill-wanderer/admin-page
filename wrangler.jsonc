{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "admin-page",
  "compatibility_date": "2026-06-15",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "dist/admin-page-temp/browser/index.html",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
